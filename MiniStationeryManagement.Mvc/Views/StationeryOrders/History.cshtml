@model List<MiniStationeryManagement.Mvc.Models.StationeryOrder>

@{
    ViewData["Title"] = "Lịch sử Giao dịch (Orders History)";
}

<div class="container mt-4">
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-title text-primary"><i class="bi bi-clock-history"></i> Lịch Sử Giao Dịch</h2>
            <p class="page-description text-muted">Danh sách các đơn hàng đã đặt trong hệ thống và thông tin chi tiết các mặt hàng đi kèm.</p>
        </div>
        <a class="btn btn-outline-secondary" href="/Stationery">
            <i class="bi bi-arrow-left"></i> Về danh sách sản phẩm
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info py-5 text-center shadow-sm rounded">
            <i class="bi bi-info-circle fs-2 text-info"></i>
            <h4 class="mt-3">Chưa có giao dịch nào được ghi nhận</h4>
            <p class="text-muted mb-0">Hãy quay lại danh sách sản phẩm và thực hiện đặt hàng để thấy dữ liệu tại đây.</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var order in Model)
            {
                <div class="col-12 mb-4">
                    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
                        <div class="card-header bg-dark text-white p-3 d-flex justify-content-between align-items-center">
                            <div>
                                <span class="badge bg-primary me-2">ĐƠN HÀNG #@order.Id</span>
                                <span class="text-white-50"><i class="bi bi-person-fill"></i> Khách hàng: <strong>@order.CustomerName</strong></span>
                            </div>
                            <div class="text-end">
                                <span class="text-white-50 me-3"><i class="bi bi-calendar-event"></i> @order.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</span>
                                <span class="fs-5 fw-bold text-warning">Tổng tiền: @order.TotalAmount.ToString("N0") đ</span>
                            </div>
                        </div>
                        <div class="card-body bg-white p-0">
                            <table class="table table-hover align-middle mb-0" style="border-top: none;">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 15%; padding-left: 20px;">Mã SKU</th>
                                        <th style="width: 15%">Mã Barcode</th>
                                        <th style="width: 35%">Tên văn phòng phẩm</th>
                                        <th style="width: 15%" class="text-center">Số lượng mua</th>
                                        <th style="width: 20%" class="text-end" style="padding-right: 20px;">Đơn giá</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in order.OrderItems)
                                    {
                                        <tr>
                                            <td style="padding-left: 20px;"><span class="badge bg-secondary">@(item.StationeryItem?.Sku ?? "N/A")</span></td>
                                            <td><small class="text-muted">@(item.StationeryItem?.Barcode ?? "N/A")</small></td>
                                            <td class="fw-bold">@(item.StationeryItem?.Name ?? "Sản phẩm đã bị xóa")</td>
                                            <td class="text-center"><span class="badge bg-info text-dark fw-bold">@item.Quantity</span></td>
                                            <td class="text-end fw-bold text-primary" style="padding-right: 20px;">@item.UnitPrice.ToString("N0") đ</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
