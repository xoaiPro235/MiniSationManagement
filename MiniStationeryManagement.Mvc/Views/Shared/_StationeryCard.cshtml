@model MiniStationeryManagement.Mvc.ViewModels.StationeryListItemViewModel

<div>
    <h4>@Model.Name</h4>
    <p>Danh mục: @Model.CategoryName</p>
    <p>Giá: @Model.Price.ToString("N0") đ</p>
    <p>Tồn kho: @Model.Quantity</p>
    <p>
        Trạng thái: 
        @if (Model.Quantity <= 0)
        {
            <span>Hết hàng</span>
        }
        else
        {
            <span>Còn hàng</span>
        }
    </p>
    <a asp-controller="Stationery" asp-action="Detail" asp-route-id="@Model.Id">Xem chi tiết</a>
</div>
