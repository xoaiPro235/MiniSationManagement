<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Stationery Management</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>
    <header class="site-header">
        <div class="container header-content">
            <div class="brand">
                <a asp-controller="Stationery" asp-action="Index">Stationery Management</a>
            </div>

            <nav class="main-nav">
                <a asp-controller="Home" asp-action="Index">Dashboard</a>
                <a asp-controller="Stationery" asp-action="Index">Products</a>
                <a asp-controller="Categories" asp-action="Index">Categories</a>
                <a asp-controller="Stationery" asp-action="Search">Search</a>
                <a asp-controller="Stationery" asp-action="Create">Create</a>
                <a asp-controller="Stationery" asp-action="Trash" class="text-warning">🗑️ Trash</a>
                <a asp-controller="AuditLogs" asp-action="Index">Audit Logs</a>
                <a href="/health/ready" target="_blank">Health</a>
                <a href="/api/stationery/9999" target="_blank" class="text-danger">API Error</a>
                <a asp-controller="StationeryOrders" asp-action="History">History</a>
                <a asp-controller="DataHealth" asp-action="Index">Data Health</a>
            </nav>
        </div>
    </header>

    <main class="container main-content">
        @if (TempData["Success"] != null)
        {
            <div class="message-success" style="padding: 10px; margin-bottom: 15px; color: #155724; background-color: #d4edda; border: 1px solid #c3e6cb;">
                @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="message-error" style="padding: 10px; margin-bottom: 15px; color: #721c24; background-color: #f8d7da; border: 1px solid #f5c6cb;">
                @TempData["Error"]
            </div>
        }

        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container footer-content">
            <span>&copy; 2026 - MiniStationeryManagement - Lab04</span>
            <a href="#">Privacy</a>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
