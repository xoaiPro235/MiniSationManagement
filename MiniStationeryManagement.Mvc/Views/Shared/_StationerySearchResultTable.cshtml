@model List<MiniStationeryManagement.Mvc.ViewModels.StationeryListItemViewModel>

@if (Model == null || !Model.Any())
{
    <div class="text-center text-danger py-4">
        <i class="bi bi-emoji-frown fs-3"></i>
        <p class="mt-2 mb-0">Không tìm thấy văn phòng phẩm nào phù hợp với tiêu chí tìm kiếm.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-striped table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Mã SKU</th>
                    <th>Mã Barcode</th>
                    <th>Tên văn phòng phẩm</th>
                    <th>Danh mục</th>
                    <th>Nhà cung cấp</th>
                    <th class="text-end">Đơn giá</th>
                    <th class="text-center">Số lượng kho</th>
                    <th class="text-center" style="width: 320px;">Thao tác quản trị</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="badge bg-secondary p-2">@item.Sku</span></td>
                        <td><small class="text-muted">@item.Barcode</small></td>
                        <td class="fw-bold">@item.Name</td>
                        <td>@item.CategoryName</td>
                        <td><small class="text-muted">@item.Supplier</small></td>
                        <td class="text-end text-primary fw-bold">@item.Price.ToString("N0") đ</td>
                        <td class="text-center">
                            <span class="fw-bold">@item.Quantity</span>
                            @if (item.IsLowStock)
                            {
                                <span class="badge bg-danger ms-2">Sắp hết</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                <a asp-controller="Stationery" asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" style="padding: 4px 8px; border-radius: 4px; font-size: 0.85rem;">
                                    <i class="bi bi-eye"></i> Xem
                                </a>
                                <a asp-controller="Stationery" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" style="padding: 4px 8px; border-radius: 4px; font-size: 0.85rem;">
                                    <i class="bi bi-pencil"></i> Sửa
                                </a>
                                <a asp-controller="Stationery" asp-action="AdjustStock" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success" style="padding: 4px 8px; border-radius: 4px; font-size: 0.85rem;">
                                    <i class="bi bi-plus-slash-minus"></i> Kho
                                </a>
                                <a asp-controller="Stationery" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" style="padding: 4px 8px; border-radius: 4px; font-size: 0.85rem;">
                                    <i class="bi bi-trash"></i> Xóa
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
