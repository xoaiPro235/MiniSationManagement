@model IEnumerable<MiniStationeryManagement.Mvc.ViewModels.StationeryListItemViewModel>

@if (Model == null || !Model.Any())
{
    <p>Không tìm thấy sản phẩm văn phòng phẩm nào phù hợp với bộ lọc.</p>
}
else
{
    <table border="1">
        <thead>
            <tr>
                <th>Tên sản phẩm</th>
                <th>Danh mục</th>
                <th>Giá bán</th>
                <th>Tồn kho</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.CategoryName</td>
                    <td>@item.Price.ToString("N0") đ</td>
                    <td>@item.Quantity</td>
                    <td>
                        @if (item.Quantity <= 0)
                        {
                            <span>Hết hàng</span>
                        }
                        else
                        {
                            <span>Còn hàng</span>
                        }
                    </td>
                    <td>
                        <a asp-controller="Stationery" asp-action="Detail" asp-route-id="@item.Id">Xem chi tiết</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
