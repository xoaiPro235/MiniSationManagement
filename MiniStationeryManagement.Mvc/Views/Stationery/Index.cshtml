@model List<MiniStationeryManagement.Mvc.ViewModels.StationeryListItemViewModel>
@{
    ViewData["Title"] = "Danh mục Văn phòng phẩm";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Cửa hàng Văn phòng phẩm</h2>
        <p class="page-description">Quản lý nâng cấp danh sách sản phẩm bằng Layout & Partial View.</p>
    </div>
    <div>
        <a class="btn btn-secondary" asp-controller="Stationery" asp-action="Search">Tra cứu sản phẩm</a>
        <a class="btn" asp-controller="Stationery" asp-action="Create">+ Thêm sản phẩm</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="success-box">
        @TempData["SuccessMessage"]
    </div>
}

<div class="info-box">
    <strong>Tổng quy mô mặt hàng hiện tại:</strong> @Model.Count sản phẩm.
</div>

@if (Model.Count == 0)
{
    <p>Hệ thống trống. Vui lòng bấm nút Thêm để bổ sung sản phẩm.</p>
}
else
{
    <div class="product-grid">
        @foreach (var item in Model)
        {
            <partial name="_StationeryCard" model="item" />
        }
    </div>
}
