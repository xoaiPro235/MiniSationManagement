@model List<MiniStationeryManagement.Mvc.ViewModels.StationeryListItemViewModel>

@{
    ViewData["Title"] = "Danh Sách Văn Phòng Phẩm";
}

<div class="container mt-4">
    <h2>Quản Lý Kho Văn Phòng Phẩm - Lab 04 Upgrade</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Thành công!</strong> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Lỗi hệ thống:</strong> @TempData["Error"]
        </div>
    }

    <form method="get" action="@Url.Action("Index", "Stationery")" class="row g-3 my-3 p-3 bg-light border rounded shadow-sm">
        <div class="col-md-4">
            <label class="form-label fw-bold">Danh mục vật tư</label>
            <select name="categoryId" class="form-select">
                <option value="">-- Tất cả danh mục --</option>
                <option value="1">Bút & Viết</option>
                <option value="2">Giấy & Sổ viết</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold">Giá tối thiểu (đ)</label>
            <input type="number" name="minPrice" class="form-control" placeholder="Ví dụ: 2000" />
        </div>
        <div class="col-md-3">
            <label class="form-label fw-bold">Giá tối đa (đ)</label>
            <input type="number" name="maxPrice" class="form-control" placeholder="Ví dụ: 100000" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-funnel"></i> Lọc dữ liệu
            </button>
        </div>
    </form>

    <style>
        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 24px;
        }
        .product-card {
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            background-color: #ffffff;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
        }
        @@keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }
    </style>

    <div class="product-grid mt-4">
        @foreach (var item in Model)
        {
            <div class="product-card shadow-sm p-3 position-relative">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="badge bg-primary text-white" style="font-size: 0.75rem; padding: 5px 10px; border-radius: 6px;">@item.CategoryName</span>
                    <span class="badge bg-light text-dark border" style="font-size: 0.75rem; padding: 4px 8px;">SKU: @item.Sku</span>
                </div>
                
                <h4 class="fw-bold text-dark mt-2 mb-1" style="font-size: 1.15rem; min-height: 2.8rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4;">@item.Name</h4>
                
                <div class="text-muted small mb-2">
                    <div class="mb-1"><i class="bi bi-building"></i> NCC: <strong class="text-secondary">@item.Supplier</strong></div>
                    <div><i class="bi bi-upc-scan"></i> Barcode: <strong class="text-secondary">@item.Barcode</strong></div>
                </div>

                <div class="d-flex justify-content-between align-items-center my-3">
                    <div class="product-price text-danger fw-bold m-0" style="font-size: 1.25rem;">
                        @item.Price.ToString("N0") đ
                    </div>
                    <div class="text-end">
                        <span class="small text-muted">Kho: </span>
                        <span class="fw-bold text-dark" style="font-size: 1.05rem;">@item.Quantity</span>
                        @if (item.IsLowStock)
                        {
                            <div class="badge bg-danger text-white mt-1 d-block" style="font-size: 0.7rem; padding: 3px 6px; animation: pulse 1.5s infinite;">Sắp hết hàng</div>
                        }
                    </div>
                </div>

                <div class="d-flex gap-2 mt-2 pt-2 border-top">
                    <a asp-controller="Stationery" asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm flex-grow-1 text-center d-flex align-items-center justify-content-center" style="border: 1px solid #0d6efd; background-color: transparent; color: #0d6efd; border-radius: 6px; font-weight: 500;">
                        <i class="bi bi-eye me-1"></i> Chi tiết
                    </a>
                    
                    <form asp-controller="StationeryOrders" asp-action="PlaceOrder" method="post" class="flex-grow-1 m-0">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="items[0].ItemId" value="@item.Id" />
                        <input type="hidden" name="customerName" value="Mai Văn Lực" />
                        <input type="hidden" name="items[0].Quantity" value="1" />
                        <button type="submit" class="btn btn-sm w-100 text-center d-flex align-items-center justify-content-center" style="background-color: #198754; border: none; border-radius: 6px; color: white; font-weight: 500; padding: 8px 12px;">
                            <i class="bi bi-cart-plus me-1"></i> Mua nhanh
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
