@model MiniStationeryManagement.Mvc.ViewModels.StationerySearchViewModel

@{
    ViewData["Title"] = "Tìm kiếm Văn phòng phẩm (AJAX)";
}

<h2>@ViewData["Title"]</h2>

<form id="ajaxSearchForm" method="get">
    <div>
        <label for="keyword">Từ khóa:</label>
        <input type="text" id="keyword" name="keyword" placeholder="Nhập tên sản phẩm..." />
    </div>

    <div>
        <label for="categoryId">Danh mục:</label>
        <select id="categoryId" name="categoryId">
            <option value="">-- Tất cả danh mục --</option>
            @if (ViewBag.Categories != null)
            {
                foreach (var cat in ViewBag.Categories)
                {
                    <option value="@cat.Value">@cat.Text</option>
                }
            }
        </select>
    </div>

    <button type="submit">Tìm kiếm</button>
</form>

<hr />

<div id="searchResultArea">
    <p>Nhập từ khóa và nhấn Tìm kiếm để xem kết quả...</p>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#ajaxSearchForm").on("submit", function (e) {
                e.preventDefault(); // Chặn reload trang

                $("#searchResultArea").html('<p>Đang tìm kiếm...</p>');

                var keywordVal = $("#keyword").val();
                var categoryIdVal = $("#categoryId").val();

                $.ajax({
                    url: '@Url.Action("PerformSearch", "Stationery")',
                    type: 'GET',
                    data: { 
                        keyword: keywordVal, 
                        categoryId: categoryIdVal 
                    },
                    success: function (response) {
                        $("#searchResultArea").html(response);
                    },
                    error: function () {
                        $("#searchResultArea").html('<p>Đã xảy ra lỗi khi tìm kiếm.</p>');
                    }
                });
            });
        });
    </script>
}hr.readyState === 4 && xhr.status === 200) {
                    // Đắp mảnh HTML của bảng kết quả vào vùng hiển thị mà không reload trang
                    document.getElementById('search-results').innerHTML = xhr.responseText;
                }
            };
            xhr.send();
        }
    </script>
}
