@model MiniStationeryManagement.Mvc.ViewModels.StationerySearchViewModel
@{
    ViewData["Title"] = "Tra cứu văn phòng phẩm";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Bộ lọc tìm kiếm văn phòng phẩm</h2>
        <p class="page-description">Sử dụng Form GET và Query String để truyền trạng thái lọc dữ liệu.</p>
    </div>
    <a class="btn btn-light" asp-controller="Stationery" asp-action="Index">Quay lại trang chủ</a>
</div>

<div class="form-layout">
    <form class="form-box" asp-controller="Stationery" asp-action="Search" method="get">
        <div class="form-group">
            <label asp-for="Keyword">Từ khóa tìm kiếm</label>
            <input asp-for="Keyword" class="form-control" placeholder="Nhập tên, danh mục hoặc SKU..." />
        </div>
        <div class="form-group">
            <label asp-for="MinPrice">Giá bán tối thiểu từ (VND)</label>
            <input asp-for="MinPrice" class="form-control" placeholder="Ví dụ: 20000" />
        </div>
        <div class="form-group">
            <label asp-for="Supplier">Nhà cung cấp</label>
            <input asp-for="Supplier" class="form-control" placeholder="Nhập tên đơn vị cung ứng..." />
        </div>
        <button class="btn" type="submit">Tìm kiếm</button>
        <a class="btn btn-secondary" asp-controller="Stationery" asp-action="Search">Xóa bộ lọc</a>
    </form>

    <div>
        <h3>Kết quả tra cứu</h3>
        <p>Từ khóa hiện tại: <strong>@Model.Keyword</strong> | Giá sàn: <strong>@Model.MinPrice</strong></p>

        @if (Model.StationeryItems.Count == 0)
        {
            <div class="info-box" style="background: #fef08a; border-color: #facc15; color: #854d0e;">
                <strong>Thông báo:</strong> Không tìm thấy sản phẩm văn phòng phẩm nào phù hợp. Vui lòng thử lại với từ khóa khác!
            </div>
        }
        else
        {
            <partial name="_StationerySearchResultTable" model="Model.StationeryItems" />
        }
    </div>
</div>
