@model MiniStationeryManagement.Mvc.ViewModels.StationeryEditViewModel
@{
    ViewData["Title"] = "Cập nhật văn phòng phẩm";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Cập nhật Văn phòng phẩm</h2>
        <p class="page-description">Chỉnh sửa thông tin sản phẩm và kiểm soát xung đột đồng thời (Concurrency Control) qua RowVersion.</p>
    </div>
    <a class="btn btn-light" asp-controller="Stationery" asp-action="Index">Hủy bỏ</a>
</div>

<div class="form-layout">
    <form class="form-box" asp-controller="Stationery" asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="RowVersion" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-group">
            <label asp-for="Sku">Mã định danh định chuẩn (SKU)</label>
            <input asp-for="Sku" class="form-control" placeholder="Ví dụ: PEN-PILOT-01" />
            <span asp-validation-for="Sku" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Barcode">Mã vạch sản phẩm (Barcode)</label>
            <input asp-for="Barcode" class="form-control" placeholder="Ví dụ: 8935212312341" />
            <span asp-validation-for="Barcode" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Name">Tên sản phẩm văn phòng phẩm</label>
            <input asp-for="Name" class="form-control" placeholder="Ví dụ: Bút bi Thiên Long" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="CategoryId">Nhóm danh mục vật tư</label>
            <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.Categories">
                <option value="">-- Chọn danh mục liên kết --</option>
            </select>
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Supplier">Công ty cung ứng</label>
            <input asp-for="Supplier" class="form-control" placeholder="Ví dụ: Tập đoàn Thiên Long" />
            <span asp-validation-for="Supplier" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Price">Đơn giá bán (VND)</label>
            <input asp-for="Price" class="form-control" type="number" step="0.01" placeholder="Ví dụ: 5000" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Quantity">Số lượng tồn kho</label>
            <input asp-for="Quantity" class="form-control" type="number" placeholder="Ví dụ: 100" />
            <span asp-validation-for="Quantity" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="MinStock">Mức tồn kho tối thiểu</label>
            <input asp-for="MinStock" class="form-control" type="number" placeholder="Ví dụ: 5" />
            <span asp-validation-for="MinStock" class="text-danger"></span>
        </div>

        <button class="btn btn-primary" type="submit">Lưu thay đổi</button>
    </form>

    <div class="info-box">
        <h3>Kiểm soát xung đột đồng thời</h3>
        <p>Hệ thống sử dụng kỹ thuật <strong>Optimistic Concurrency Control</strong> dựa trên <code>RowVersion</code>. Khi dữ liệu được lưu, SQL Server / PostgreSQL sẽ kiểm tra xem phiên bản bản ghi trong DB có khớp với token đính kèm trong form hay không.</p>
        <p>Nếu người dùng khác đã sửa đổi sản phẩm trước khi bạn nhấn lưu, hệ thống sẽ phát hiện xung đột và hiển thị thông báo lỗi thay vì ghi đè dữ liệu cũ.</p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
