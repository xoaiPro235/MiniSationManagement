@model MiniStationeryManagement.Mvc.ViewModels.StationeryStatsViewModel

@{
    ViewData["Title"] = "Thống Kê Kho Hàng";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Inventory Stats</h2>
        <p class="page-description">Báo cáo tổng quan số lượng, giá trị và các chỉ số cảnh báo nhập hàng.</p>
    </div>

    <a class="btn" href="/Stationery" style="text-decoration: none; padding: 8px 16px; border: 1px solid #ccc; border-radius: 4px; background: #fff; color: #333;">
        ← Quay lại danh sách
    </a>
</div>

<div class="stat-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-top: 20px;">
    <div class="stat-card" style="padding: 20px; background: #fff; border: 1px solid #eee; border-radius: 8px; text-align: center;">
        <div class="stat-number" style="font-size: 2em; font-weight: bold; color: #333;">@Model.TotalItemTypes</div>
        <div class="stat-label" style="color: #666; font-size: 0.9em; margin-top: 5px;">Tổng số loại sản phẩm</div>
    </div>

    <div class="stat-card" style="padding: 20px; background: #fff; border: 1px solid #eee; border-radius: 8px; text-align: center;">
        <div class="stat-number" style="font-size: 2em; font-weight: bold; color: #198754;">@Model.TotalQuantity</div>
        <div class="stat-label" style="color: #666; font-size: 0.9em; margin-top: 5px;">Tổng số lượng tồn kho</div>
    </div>

    <div class="stat-card" style="padding: 20px; background: #fff; border: 1px solid #eee; border-radius: 8px; text-align: center;">
        <div class="stat-number" style="font-size: 2em; font-weight: bold; color: #0d6efd;">@Model.TotalInventoryValue.ToString("N0") đ</div>
        <div class="stat-label" style="color: #666; font-size: 0.9em; margin-top: 5px;">Tổng giá trị hàng tồn</div>
    </div>

    <div class="stat-card" style="padding: 20px; background: #fff; border: 1px solid #eee; border-radius: 8px; text-align: center;">
        <div class="stat-number" style="font-size: 2em; font-weight: bold; color: #ffc107;">@Model.LowStockItemsCount</div>
        <div class="stat-label" style="color: #666; font-size: 0.9em; margin-top: 5px;">Sản phẩm chạm mốc tối thiểu</div>
    </div>
</div>

<div class="info-panel" style="padding: 15px; background: #fff3cd; border: 1px solid #ffeeba; border-radius: 8px; margin: 20px 0; color: #856404;">
    <div style="display: flex; align-items: center; gap: 10px;">
        <span style="font-size: 1.5em;">📢</span>
        <div>
            <strong style="display: block; margin-bottom: 2px;">Đánh giá tình hình tồn kho (Feature 1 - Options):</strong>
            @if (Model.LowStockItemsCount > 0)
            {
                <span>⏳ Phát hiện thấy có <strong>@Model.LowStockItemsCount</strong> mặt hàng sắp hết kho theo ngưỡng thiết lập. Nên lên kế hoạch nhập hàng gấp.</span>
            }
            else
            {
                <span>✅ Trạng thái quản lý lượng hàng trong kho hiện tại đang rất ổn định và an toàn.</span>
            }
        </div>
    </div>
</div>

<div style="background: #fff; border-radius: 8px; border: 1px solid #eee; overflow: hidden; margin-top: 20px;">
    <table class="table" style="width: 100%; border-collapse: collapse;">
        <tbody>
            <tr style="border-bottom: 1px solid #eee;">
                <th style="width: 40%; padding: 12px; text-align: left; background: #f9f9f9;">Tổng số loại danh mục vật tư hiện hữu</th>
                <td style="padding: 12px; font-weight: bold;">@Model.TotalItemTypes nhóm phân loại</td>
            </tr>
            <tr style="border-bottom: 1px solid #eee;">
                <th style="padding: 12px; text-align: left; background: #f9f9f9;">Tổng dung lượng lưu trữ thực tế</th>
                <td style="padding: 12px; font-weight: bold; color: #198754;">@Model.TotalQuantity sản phẩm trong kho</td>
            </tr>
            <tr style="border-bottom: 1px solid #eee;">
                <th style="padding: 12px; text-align: left; background: #f9f9f9;">Tổng kinh phí vốn lưu động</th>
                <td style="padding: 12px; font-weight: bold; color: #0d6efd;">@Model.TotalInventoryValue.ToString("N0") đ</td>
            </tr>
            <tr style="border-bottom: 1px solid #eee;">
                <th style="padding: 12px; text-align: left; background: #f9f9f9;">Số lượng văn phòng phẩm cần mua thêm</th>
                <td style="padding: 12px;"><span style="padding: 3px 8px; background: #fff3cd; color: #856404; border-radius: 4px; font-weight: bold;">@Model.LowStockItemsCount sản phẩm</span></td>
            </tr>
        </tbody>
    </table>
</div>
