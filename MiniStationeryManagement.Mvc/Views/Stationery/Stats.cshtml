@model StationeryStatsViewModel

@{
    ViewData["Title"] = "Inventory Stats";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Inventory Stats</h2>
        <p class="page-description">Báo cáo tổng quan số lượng, giá trị và các chỉ số cảnh báo nhập hàng.</p>
    </div>

    <a class="btn btn-outline-secondary px-4" href="/Stationery">
        ← Quay lại danh sách
    </a>
</div>

<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-number">@Model.TotalItemTypes</div>
        <div class="stat-label">Tổng số loại sản phẩm</div>
    </div>

    <div class="stat-card">
        <div class="stat-number text-success">@Model.TotalQuantity</div>
        <div class="stat-label">Tổng số lượng tồn kho</div>
    </div>

    <div class="stat-card">
        <div class="stat-number text-primary">@Model.TotalInventoryValueText</div>
        <div class="stat-label">Tổng giá trị tồn kho</div>
    </div>

    <div class="stat-card">
        <div class="stat-number text-danger">@Model.OutOfStockCount</div>
        <div class="stat-label">Sản phẩm đã hết hàng</div>
    </div>

    <div class="stat-card">
        <div class="stat-number text-warning">@Model.NeedReorderCount</div>
        <div class="stat-label">Sản phẩm cần nhập thêm</div>
    </div>
</div>

<div class="info-panel shadow-sm my-4">
    <div class="d-flex align-items-center gap-2">
        <span class="fs-4">📢</span>
        <div>
            <strong class="d-block mb-1">Đánh giá tình hình tồn kho:</strong>
            @if (Model.OutOfStockCount > 0)
            {
                <span class="text-danger fw-semibold">⚠️ Có sản phẩm đã hết hàng. Cần kiểm tra và nhập thêm sớm.</span>
            }
            else if (Model.NeedReorderCount > 0)
            {
                <span class="text-warning fw-semibold">⏳ Một số sản phẩm gần chạm mốc tối thiểu. Nên lập kế hoạch nhập thêm.</span>
            }
            else
            {
                <span class="text-success fw-semibold">✅ Tồn kho hiện tại đang rất ổn định và an toàn.</span>
            }
        </div>
    </div>
</div>

<div class="bg-white rounded-4 border shadow-sm overflow-hidden mt-4">
    <table class="table mb-0">
        <tbody>
            <tr>
                <th style="width: 40%">Tổng số loại sản phẩm</th>
                <td class="fw-bold">@Model.TotalItemTypes loại</td>
            </tr>
            <tr>
                <th>Tổng số lượng tồn kho</th>
                <td class="fw-bold text-success">@Model.TotalQuantity đơn vị</td>
            </tr>
            <tr>
                <th>Tổng giá trị tồn kho</th>
                <td class="fw-bold text-primary">@Model.TotalInventoryValueText</td>
            </tr>
            <tr>
                <th>Số sản phẩm đã hết hàng</th>
                <td><span class="badge badge-danger">@Model.OutOfStockCount sản phẩm</span></td>
            </tr>
            <tr>
                <th>Số sản phẩm cần nhập thêm</th>
                <td><span class="badge badge-warning">@Model.NeedReorderCount sản phẩm</span></td>
            </tr>
        </tbody>
    </table>
</div>
